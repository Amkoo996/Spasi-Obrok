rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; 
    }

    match /users/{userId} {
      // In production, we should restrict updates of "role" and "points" to server/admin.
      // For MVP scale and fast iteration, we allow users to read/write their own profile
      // and partners/admins to read them.
      allow read, write: if request.auth != null;
    }

    match /offers/{offerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }

    match /system/{document=**} {
      allow read, write: if true;
    }
  }
}
